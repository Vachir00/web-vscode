<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <style>
        /* Ajustes para que Editor.js se vea impecable en modo oscuro */
        .editorjs-container {
            background: #1e1e1e;
            border: 1px solid #444;
            border-radius: 4px;
            padding: 20px;
            color: #fff;
            flex-grow: 1;
            overflow-y: auto;
        }
        /* Color del texto seleccionado o placeholders */
        .ce-paragraph[data-placeholder] { color: #666 !important; }
        .ce-block--selected .ce-block__content { background: #2d2d2d; }
        .ce-toolbar__plus, .ce-toolbar__settings-btn { background-color: #333 !important; color: #fff !important; }
        .cdx-block { color: #fff; }
        /* Estilo para bloques de código dentro de tus notas */
        .ce-code__textarea { background: #111 !important; color: #4cd137 !important; border: 1px solid #333 !important; font-family: monospace; }
    </style>
</head>
<body>
<div class="main-container">
    <nav class="main-sidebar">
        <ul>
            <li><a href="/">Editor</a></li>
            <li><a href="/curl">cURL</a></li>
            <li><a href="/database">Databases</a></li>
            <li class="active"><a href="/brain">Brain</a></li>
        </ul>
        <div class="version-info">Versión 0.1</div>
    </nav>

    <div class="editor-view">
        <aside class="file-sidebar">
            <h4>Notas</h4>
            <div class="file-actions">
                <button id="new-note-btn" class="btn-secondary" style="width: 100%;">Nueva Nota</button>
            </div>
            <div id="notes-list" class="file-list" style="margin-top: 10px;">
            </div>
        </aside>

        <main class="editor-container" style="display: flex; flex-direction: column; padding: 20px; gap: 15px; box-sizing: border-box; height: 100vh;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <input type="text" id="note-title" placeholder="Título de tu nota..." style="background: transparent; border: none; border-bottom: 2px solid #333; color: #fff; font-size: 22px; font-weight: bold; width: 70%; padding: 5px 0; outline: none;">
                <button id="save-note-btn" class="btn-primary" style="padding: 8px 20px;">Guardar Nota</button>
            </div>

            <div id="editorjs" class="editorjs-container"></div>
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@editorjs/editorjs@latest"></script>

<script src="https://cdn.jsdelivr.net/npm/@editorjs/header@latest"></script>
<script src="https://cdn.jsdelivr.net/npm/@editorjs/list@latest"></script>
<script src="https://cdn.jsdelivr.net/npm/@editorjs/code@latest"></script>

<script src="/javascripts/brain.js"></script>
</body>
</html>