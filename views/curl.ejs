<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
</head>
<body>
<div class="main-container">
    <nav class="main-sidebar">
        <ul>
            <li><a href="/">Editor</a></li>
            <li class="active"><a href="/curl">cURL</a></li>
            <li><a href="/database">Databases</a></li>
        </ul>
        <div class="version-info">
            Versión 0.1
        </div>
    </nav>

    <div class="editor-view">
        <aside id="curl-sidebar" class="file-sidebar">
            <h4>Historial</h4>
            <div id="history-list" class="file-list">
                <p style="color: #666; padding: 10px; font-size: 12px;">Sin peticiones recientes</p>
            </div>
        </aside>

        <main class="editor-container" style="display: flex; flex-direction: column; padding: 15px; box-sizing: border-box; gap: 15px; overflow-y: auto;">

            <div style="display: flex; gap: 10px; align-items: center;">
                <select id="request-method" style="padding: 10px; background: #2d2d2d; color: #fff; border: 1px solid #444; border-radius: 4px; font-weight: bold;">
                    <option value="GET">GET</option>
                    <option value="POST">POST</option>
                    <option value="PUT">PUT</option>
                    <option value="DELETE">DELETE</option>
                    <option value="PATCH">PATCH</option>
                </select>
                <input type="text" id="request-url" placeholder="https://api.ejemplo.com/v1/usuarios" style="flex-grow: 1; padding: 10px; background: #1e1e1e; color: #fff; border: 1px solid #444; border-radius: 4px;">
                <button id="send-request-btn" class="btn-primary" style="padding: 10px 20px;">Enviar</button>
            </div>

            <div style="background: #1e1e1e; border: 1px solid #444; border-radius: 4px; padding: 10px; position: relative;">
                <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #333; padding-bottom: 5px; margin-bottom: 8px;">
                    <h5 style="margin: 0; color: #aaa; font-size: 12px;">Comando cURL Equivalente</h5>
                    <button id="copy-curl-btn" style="background: #2d2d2d; color: #aaa; border: 1px solid #444; border-radius: 4px; padding: 2px 8px; font-size: 11px; cursor: pointer; transition: all 0.2s;">
                        Copiar
                    </button>
                </div>
                <div id="curl-preview-container" style="height: 60px; border: 1px solid #333;"></div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr; gap: 15px;">
                <div style="background: #1e1e1e; border: 1px solid #444; border-radius: 4px; padding: 10px;">
                    <h5 style="margin-top: 0; color: #aaa; border-bottom: 1px solid #333; padding-bottom: 5px;">Headers (JSON format)</h5>
                    <div id="headers-editor-container" style="height: 100px; border: 1px solid #333;"></div>
                </div>

                <div id="body-panel" style="background: #1e1e1e; border: 1px solid #444; border-radius: 4px; padding: 10px;">
                    <h5 style="margin-top: 0; color: #aaa; border-bottom: 1px solid #333; padding-bottom: 5px;">Body (JSON)</h5>
                    <div id="body-editor-container" style="height: 150px; border: 1px solid #333;"></div>
                </div>
            </div>

            <div style="flex-grow: 1; display: flex; flex-direction: column; background: #1e1e1e; border: 1px solid #444; border-radius: 4px; padding: 10px; min-height: 250px;">
                <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #333; padding-bottom: 5px; margin-bottom: 10px;">
                    <h5 style="margin: 0; color: #aaa;">Respuesta</h5>
                    <div style="display: flex; gap: 15px; font-size: 13px; align-items: center;">
                        <span id="response-status" style="font-weight: bold;"></span>
                        <span id="response-time" style="color: #888;"></span>
                        <button id="copy-response-btn" style="background: #2d2d2d; color: #aaa; border: 1px solid #444; border-radius: 4px; padding: 2px 8px; font-size: 11px; cursor: pointer; transition: all 0.2s;">
                            Copiar
                        </button>
                    </div>
                </div>
                <div id="response-editor-container" style="flex-grow: 1; border: 1px solid #333; min-height: 180px;"></div>
            </div>

        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.49.0/min/vs/loader.js"></script>
<script src="/javascripts/curl.js"></script>
</body>
</html>